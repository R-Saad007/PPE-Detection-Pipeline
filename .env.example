# Flask
FLASK_ENV=development
FLASK_PORT=5000

# Directory paths
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
DEAD_LETTER_DIR=failed

# HuggingFace model (11-class: Hardhat, Safety Vest, NO-Hardhat, NO-Safety Vest, etc.)
HF_MODEL_REPO=yihong1120/Construction-Hazard-Detection
HF_MODEL_FILE=models/yolo11/pt/yolo11m.pt

# Image validation
MAX_IMAGE_SIZE_MB=20

# Logging
LOG_LEVEL=INFO

# Detection thresholds
PERSON_CONF_THRESHOLD=0.25
PPE_CONF_THRESHOLD=0.35
# Site ROI — normalised rectangle to exclude persons outside the gate
# SITE_ROI=0.05,0.0,0.85,1.0

# Annotation (true = draw individual PPE boxes; false = person box only)
DRAW_PPE_BOXES=true

# Phase 2 — FTP watcher (not used until Digital Ocean deployment)
FTP_WATCH_DIR=/ftp/uploads
POLL_INTERVAL_SEC=2
